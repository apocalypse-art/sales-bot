# ─── Twitter / X API Credentials ─────────────────────────────────────────────
# Get these from: https://developer.twitter.com/en/portal/dashboard
# Create a project → App → Keys and Tokens
# Make sure the app has READ and WRITE permissions

TWITTER_APP_KEY=your_api_key_here
TWITTER_APP_SECRET=your_api_key_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_token_secret_here


# ─── Alchemy ──────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.alchemy.com
# Create an app → Webhooks → NFT Activity → copy the Signing Key shown there

ALCHEMY_SIGNING_KEY=your_alchemy_webhook_signing_key_here

# HTTPS RPC URL for your Ethereum Mainnet Alchemy app (same account as above).
# Alchemy dashboard → your app → "API Key" / "Endpoints" → copy the HTTPS URL.
# It looks like: https://eth-mainnet.g.alchemy.com/v2/XXXXXXXXXXXXXXXX
# Used to read which marketplace a sale settled through (e.g. Manifold vs OpenSea).
# If left blank, tweets still post but omit the marketplace name.
ALCHEMY_RPC_URL=your_alchemy_eth_mainnet_https_rpc_url_here


# ─── OpenSea API ──────────────────────────────────────────────────────────────
# Free API key from: https://docs.opensea.io/reference/api-keys
# (Click "Request API Key" — approval is usually instant)

OPENSEA_API_KEY=your_opensea_api_key_here


# ─── Server Port ─────────────────────────────────────────────────────────────
# Railway sets this automatically; you only need this for local testing.

PORT=3000
